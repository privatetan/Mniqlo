# Copy to .env and fill in real values. Do not commit .env.

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Background jobs (pg-boss)
PG_BOSS_DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"
PG_BOSS_SCHEMA="pgboss"
PG_BOSS_MIGRATE="true"
PG_BOSS_CREATE_SCHEMA="true"
PG_BOSS_SSL_REJECT_UNAUTHORIZED="false"
JOB_WORKER_ENABLED="true"

# App session
SESSION_SECRET="replace-with-a-long-random-secret"

# WeChat notifications
WECHAT_APPID="your_wechat_appid"
WECHAT_APPSECRET="your_wechat_appsecret"
WECHAT_TEMPLATE_ID="your_template_id_here"
WECHAT_TEMPLATE_ID_SUPER="your_template_id_super"
WECHAT_BASE_URL="http://your-server-ip:3000"

